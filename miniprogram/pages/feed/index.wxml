<view class="page">
  <!-- 顶部导航：城市固定大理 + 搜索 -->
  <view class="nav-row">
    <view class="city-tag"><text class="pin">📍</text><text>大理</text></view>
    <view class="search-pill" bindtap="onSearchTap">
      <text>🔍</text><text class="ph">搜品种、地点、特征...</text>
    </view>
  </view>

  <!-- 筛选 chip（全部 / 寻宠 / 招领）· 紧急已砍(r49) -->
  <view class="filter-row">
    <view class="chip {{filter==='all'?'active':''}}" data-filter="all" bindtap="applyFilter">全部</view>
    <view class="chip {{filter==='lost'?'active':''}}" data-filter="lost" bindtap="applyFilter">
      <text class="dot" style="background:var(--apricot)"></text>寻宠
    </view>
    <view class="chip {{filter==='found'?'active':''}}" data-filter="found" bindtap="applyFilter">
      <text class="dot" style="background:var(--mint)"></text>招领
    </view>
  </view>

  <!-- 希望叙事条 · §6.7 去成就数字(r49) -->
  <view class="stat-bar">
    <text class="sb-ic">🐾</text>
    <view class="sb-body">
      <view class="sb-line">今天有小朋友在等好心人 · 附近有人在一起找</view>
      <view class="sb-tag">每一次转发，都是一份可能的奇迹</view>
    </view>
  </view>

  <view class="section-header">
    <text class="title">大理的小朋友</text>
    <text class="count"> · {{posts.length}} 条</text>
  </view>

  <!-- 列表 -->
  <view wx:if="{{loading}}" class="hint">加载中…</view>
  <view wx:elif="{{posts.length === 0}}" class="empty">
    <view class="fe-icon">🐾</view>
    <view>附近暂时没有这类信息</view>
  </view>
  <view wx:else class="feed-list">
    <pet-card wx:for="{{posts}}" wx:key="id" post="{{item}}" bindtap="onCardTap" />
  </view>

  <view wx:if="{{fromSeed}}" class="seed-note">本地示例数据（config.js 填好 CLOUD_ENV 后接入云端）</view>

  <!-- 启动隐私协议（首启 · 不可绕过 · r127/r128/r42701ed/r7b3d4a4/rf4a9461）-->
  <view wx:if="{{showPrivacy}}" class="mask">
    <view class="modal privacy-modal">
      <view class="m-icon">🐾</view>
      <view class="m-title">欢迎使用寻宠·大理</view>
      <view class="m-sub">使用前请阅读《用户协议》与《隐私政策》</view>
      <view class="m-body">
        <view class="m-section-label">我们会收集和使用以下信息：</view>
        <view class="m-item"><text class="m-item-num">1</text><text><text class="b">位置</text> · 发布与附近匹配（精度模糊到 500m）</text></view>
        <view class="m-item"><text class="m-item-num">2</text><text><text class="b">照片</text> · 宠物识别（经平台审核）</text></view>
        <view class="m-item"><text class="m-item-num">3</text><text><text class="b">聊天内容</text> · 经审核送达，留存 6 个月以满足监管</text></view>
        <view class="m-list-footer">你可随时在「我的 → 清除我的数据」中删除所有个人数据。</view>
      </view>
      <view class="m-agree" bindtap="togglePrivacyCheck">
        <view class="m-check {{privacyChecked?'checked':''}}">{{privacyChecked?'✓':''}}</view>
        <view class="m-agree-text">
          我已阅读并同意
          <text class="m-link" catchtap="openUserAgreement">《用户协议》</text>
          和
          <text class="m-link" catchtap="openPrivacyPolicy">《隐私政策》</text>
        </view>
      </view>
      <view class="m-actions">
        <view class="m-btn secondary" bindtap="declinePrivacy">暂不使用</view>
        <view class="m-btn primary {{privacyChecked?'':'disabled'}}" bindtap="agreePrivacy">同意并继续</view>
      </view>
    </view>
  </view>

  <!-- 公众号关注（关一次后不再主动弹 · 06 第 6 条）-->
  <view wx:if="{{showMp}}" class="mask">
    <view class="modal">
      <view class="m-title">📣 关注公众号，推送更及时</view>
      <view class="m-body"><view>有人留线索 / 匹配到 ta 时，第一时间通知你。</view></view>
      <view class="m-btn primary" bindtap="followMp">去关注</view>
      <view class="m-btn ghost" bindtap="dismissMp">稍后再说</view>
    </view>
  </view>
</view>
