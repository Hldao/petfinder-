.page {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

.title-bar {
  font-size: 36rpx; font-weight: 800; color: var(--ink-1);
  padding: 36rpx 32rpx 16rpx;
}

/* Tab 栏 */
.tab-bar {
  display: flex; gap: 0;
  padding: 0 24rpx;
  border-bottom: 1rpx solid var(--divider-soft);
  margin-bottom: 16rpx;
}
.tab {
  padding: 16rpx 28rpx; font-size: 26rpx; color: var(--ink-3);
  border-bottom: 3rpx solid transparent; margin-bottom: -1rpx;
  transition: color 0.2s;
}
.tab.active { color: var(--mint-deep); font-weight: 700; border-bottom-color: var(--mint-deep); }

/* 消息列表 · r109 紧凑 */
.msg-list { padding: 0 24rpx; display: flex; flex-direction: column; gap: 12rpx; }

.msg-row {
  display: flex; gap: 24rpx; align-items: center;
  background: var(--surface);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  padding: 20rpx 28rpx;
  position: relative;
}

/* 头像 · r108 圆形 / r109 42×42 紧凑 */
.msg-avatar {
  width: 84rpx; height: 84rpx; border-radius: 50%; flex-shrink: 0;
  background: var(--apricot-soft);
  display: flex; align-items: center; justify-content: center; font-size: 40rpx;
}
.msg-avatar.orange { background: #FFE8D6; }
.msg-avatar.blue   { background: #D6E8FF; }
.msg-avatar.mint   { background: var(--mint-soft); }
.msg-avatar.cream  { background: #FFF3DC; }
.msg-avatar.sys {
  background: linear-gradient(135deg, #B0B7BF, #7A828B);
  color: #fff; font-weight: 700; font-size: 26rpx;
}

/* 正文 */
.msg-body { flex: 1; min-width: 0; }

.msg-row-head {
  display: flex; justify-content: space-between; align-items: baseline;
  gap: 12rpx; margin-bottom: 4rpx;
}
.msg-name { font-size: 28rpx; font-weight: 700; color: var(--ink-1); letter-spacing: -0.01em; }
.mp-tag {
  font-size: 18rpx; color: var(--mint-deep); background: var(--mint-soft);
  padding: 2rpx 12rpx; border-radius: var(--radius-pill);
  margin-left: 8rpx;
}
.msg-time { font-size: 21rpx; color: var(--ink-4); font-weight: 600; flex-shrink: 0; }

/* preview · r108 padding-right 56rpx 给右侧 unread 让位 */
.msg-preview {
  font-size: 24rpx; color: var(--ink-3);
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  line-height: 1.5; padding-right: 56rpx;
}
.msg-prefix {
  font-size: 24rpx; color: var(--ink-4); font-weight: 500;
  margin-right: 2rpx;
}

/* msg-context · r108 视觉降级 · 去 chip 背景 · 仅留颜色提示 */
.msg-context {
  font-size: 21rpx; color: var(--apricot-deep);
  margin-top: 6rpx; font-weight: 500;
  display: inline-block;
}
.msg-context.reply { color: var(--mint-deep); }

/* 未读 · r109 右侧垂直居中 */
.msg-unread {
  position: absolute; top: 50%; right: 28rpx;
  transform: translateY(-50%);
  width: 36rpx; height: 36rpx; border-radius: 50%;
  background: var(--apricot); color: #fff;
  font-size: 21rpx; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 4rpx 10rpx rgba(255,133,82,0.4);
}

/* 空状态 */
.empty {
  text-align: center; color: var(--ink-4); font-size: 26rpx;
  padding: 80rpx 0;
}
