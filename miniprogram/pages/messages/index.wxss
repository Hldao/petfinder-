.stub {
  min-height: 100vh; background: var(--bg);
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  padding-bottom: 120rpx;
}
.stub-ic { font-size: 96rpx; margin-bottom: 24rpx; }
.stub-title { font-size: 32rpx; font-weight: 700; color: var(--ink-1); }
.stub-sub { font-size: 24rpx; color: var(--ink-3); margin-top: 12rpx; }
