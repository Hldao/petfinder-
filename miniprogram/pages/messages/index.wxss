.page { min-height: 100vh; background: var(--bg); padding-bottom: calc(140rpx + env(safe-area-inset-bottom)); }
.title-bar { font-size: 36rpx; font-weight: 800; color: var(--ink-1); padding: 36rpx 32rpx 16rpx; }

.chat-list { padding: 0 24rpx; display: flex; flex-direction: column; gap: 16rpx; }
.chat-row {
  display: flex; gap: 20rpx; align-items: center;
  background: var(--surface); border-radius: var(--radius-md); padding: 22rpx 24rpx;
}
.avatar {
  width: 84rpx; height: 84rpx; border-radius: 24rpx; flex-shrink: 0;
  background: var(--apricot-soft); display: flex; align-items: center; justify-content: center;
  font-size: 40rpx;
}
.avatar.sys { background: var(--bg-deeper); color: var(--ink-3); font-size: 30rpx; }
.body { flex: 1; min-width: 0; }
.row1 { display: flex; align-items: baseline; gap: 12rpx; }
.peer { font-size: 28rpx; font-weight: 700; color: var(--ink-1); }
.about { font-size: 20rpx; color: var(--mint-deep); background: var(--mint-soft); padding: 2rpx 12rpx; border-radius: var(--radius-pill); }
.time { font-size: 21rpx; color: var(--ink-4); margin-left: auto; }
.preview {
  font-size: 25rpx; color: var(--ink-3); margin-top: 6rpx;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
