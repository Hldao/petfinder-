<view class="page">
  <view class="title-bar">消息</view>

  <!-- Tab 栏 -->
  <view class="tab-bar">
    <view
      class="tab {{currentTab === 'all' ? 'active' : ''}}"
      data-tab="all"
      bindtap="switchTab"
    >全部</view>
    <view
      class="tab {{currentTab === 'replies' ? 'active' : ''}}"
      data-tab="replies"
      bindtap="switchTab"
    >帖子回复</view>
    <view
      class="tab {{currentTab === 'dm' ? 'active' : ''}}"
      data-tab="dm"
      bindtap="switchTab"
    >私信</view>
  </view>

  <!-- 消息列表 -->
  <view class="msg-list">
    <view
      wx:for="{{displayMessages}}"
      wx:key="id"
      class="msg-row"
      data-msg="{{item}}"
      bindtap="openMsg"
    >
      <!-- 头像 -->
      <view class="msg-avatar {{item.avatarStyle}}">{{item.avatar}}</view>

      <!-- 正文 -->
      <view class="msg-body">
        <view class="msg-row-head">
          <view class="msg-name-wrap">
            <text class="msg-name">{{item.peerName}}</text>
            <text wx:if="{{item.mpTag}}" class="mp-tag">服务号</text>
          </view>
          <text class="msg-time">{{item.lastTime}}</text>
        </view>
        <view class="msg-preview">
          <text wx:if="{{item.prefix}}" class="msg-prefix">{{item.prefix}}</text>{{item.lastMsg}}
        </view>
        <view class="msg-context {{item.type === 'reply' ? 'reply' : ''}}">{{item.context}}</view>
      </view>

      <!-- 未读徽标 · 右侧垂直居中 -->
      <view wx:if="{{item.unread > 0}}" class="msg-unread">{{item.unread}}</view>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{displayMessages.length === 0}}" class="empty">暂无消息</view>
  </view>
</view>
