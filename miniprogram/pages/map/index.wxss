.page { position: relative; width: 100%; height: 100vh; }
.map { width: 100%; height: 100vh; }
.tip {
  position: fixed; left: 50%; top: 24rpx; transform: translateX(-50%);
  background: rgba(255,255,255,0.92); color: var(--ink-2);
  font-size: 23rpx; font-weight: 600; padding: 12rpx 28rpx; border-radius: var(--radius-pill);
  box-shadow: var(--shadow-card); z-index: 10;
}
