.page { min-height: 100vh; background: var(--bg); padding: 24rpx 32rpx 60rpx; }
.sec-title { font-size: 26rpx; font-weight: 700; color: var(--ink-2); margin: 24rpx 0 16rpx; }
.list { display: flex; flex-direction: column; gap: 24rpx; }
.hint { text-align: center; color: var(--ink-3); padding: 80rpx 0; font-size: 26rpx; }
.hint.small { padding: 32rpx 0; color: var(--ink-4); font-size: 24rpx; }
