.page { min-height: 100vh; background: var(--bg); padding: 24rpx 32rpx; }

.notice {
  background: var(--apricot-soft); color: var(--apricot-deep);
  border-radius: var(--radius-md); padding: 18rpx 24rpx;
  font-size: 22rpx; line-height: 1.5; margin-bottom: 24rpx;
}

.seg {
  display: flex; background: var(--surface); border-radius: var(--radius-pill);
  padding: 6rpx; margin-bottom: 28rpx;
}
.seg-item {
  flex: 1; text-align: center; padding: 18rpx 0;
  font-size: 28rpx; font-weight: 700; color: var(--ink-3); border-radius: var(--radius-pill);
}
.seg-item.active { background: var(--apricot); color: #fff; }

.field { margin-bottom: 28rpx; }
.label { font-size: 26rpx; font-weight: 700; color: var(--ink-1); margin-bottom: 14rpx; }
.label .req { color: var(--warn); }
.label .hint { font-size: 22rpx; color: var(--ink-3); font-weight: 400; }
.sub-hint { font-size: 21rpx; color: var(--ink-4); margin-top: 10rpx; }

.photo-row { display: flex; flex-wrap: wrap; gap: 16rpx; }
.photo-slot, .photo-add {
  width: 156rpx; height: 156rpx; border-radius: var(--radius-md); position: relative;
}
.photo-img { width: 100%; height: 100%; border-radius: var(--radius-md); }
.photo-del {
  position: absolute; top: -10rpx; right: -10rpx;
  width: 36rpx; height: 36rpx; border-radius: 50%; background: rgba(31,31,31,0.7);
  color: #fff; font-size: 22rpx; display: flex; align-items: center; justify-content: center;
}
.photo-add {
  background: var(--surface); border: 2rpx dashed var(--ink-4);
  display: flex; align-items: center; justify-content: center;
  font-size: 56rpx; color: var(--ink-4); font-weight: 300;
}

.chips { display: flex; flex-wrap: wrap; gap: 14rpx; }
.chip {
  padding: 12rpx 26rpx; background: var(--surface); border-radius: var(--radius-pill);
  font-size: 25rpx; color: var(--ink-2); font-weight: 600;
}
.chip.active { background: var(--apricot); color: #fff; }
.chip.map-pick { border: 2rpx dashed var(--apricot); color: var(--apricot-deep); background: var(--apricot-soft); }

.input, .textarea {
  width: 100%; background: var(--surface); border-radius: var(--radius-md);
  padding: 22rpx 24rpx; font-size: 27rpx; color: var(--ink-1); margin-top: 14rpx;
  box-sizing: border-box;
}
.textarea { height: 180rpx; }

.submit {
  margin-top: 16rpx; height: 92rpx; border-radius: var(--radius-pill);
  background: var(--apricot); color: #fff; font-size: 30rpx; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
}
.submit.disabled { opacity: 0.5; }
.submit:active { background: var(--apricot-deep); }
.safe-pad { height: calc(40rpx + env(safe-area-inset-bottom)); }
