.page {
  min-height: 100vh; background: var(--bg);
  display: flex; flex-direction: column;
}
.scroll-area {
  flex: 1; overflow-y: auto;
  padding: 32rpx 32rpx 200rpx;
}

/* Hero · 警示 */
.dispute-hero {
  background: var(--warn-soft);
  border-radius: var(--radius-lg);
  padding: 36rpx 32rpx;
  text-align: center;
  margin-bottom: 32rpx;
}
.dispute-icon {
  width: 96rpx; height: 96rpx;
  margin: 0 auto 20rpx;
  border-radius: 50%;
  background: var(--warn);
  color: #fff;
  display: flex; align-items: center; justify-content: center;
  font-size: 48rpx;
  box-shadow: 0 12rpx 32rpx rgba(224,78,78,0.25);
}
.dispute-title { font-size: 32rpx; font-weight: 800; color: var(--ink-1); margin-bottom: 8rpx; }
.dispute-sub { font-size: 23rpx; color: var(--ink-3); line-height: 1.6; }

/* Section label */
.section-label {
  font-size: 22rpx; color: var(--ink-3); font-weight: 700;
  letter-spacing: 0.08em; text-transform: uppercase;
  padding: 16rpx 8rpx 14rpx;
}

/* 类型 chips */
.dispute-types {
  display: grid; grid-template-columns: 1fr 1fr; gap: 16rpx;
  margin-bottom: 8rpx;
}
.dispute-type {
  background: var(--surface);
  border: 2rpx solid var(--divider-soft);
  border-radius: var(--radius-md);
  padding: 22rpx 24rpx;
  font-size: 26rpx; color: var(--ink-2);
  text-align: center;
  font-weight: 600;
}
.dispute-type.selected {
  background: var(--warn-soft);
  border-color: var(--warn);
  color: var(--warn-deep);
}

/* Block 容器 */
.dispute-block {
  background: var(--surface);
  border-radius: var(--radius-md);
  padding: 4rpx 28rpx;
  box-shadow: var(--shadow-card);
  margin-bottom: 8rpx;
}
.related-row {
  display: flex; align-items: center; justify-content: space-between;
  padding: 22rpx 0;
  font-size: 26rpx; color: var(--ink-1);
}
.related-arrow { color: var(--ink-4); font-size: 32rpx; }

.textarea {
  width: 100%; box-sizing: border-box;
  padding: 22rpx 0;
  font-size: 27rpx; color: var(--ink-1);
  min-height: 240rpx;
  line-height: 1.6;
}

/* 照片 */
.photo-row {
  display: flex; flex-wrap: wrap; gap: 16rpx;
  padding: 8rpx 0;
}
.photo-slot {
  width: 156rpx; height: 156rpx;
  border-radius: var(--radius-md);
  position: relative;
}
.photo-img { width: 100%; height: 100%; border-radius: var(--radius-md); }
.photo-del {
  position: absolute; top: -10rpx; right: -10rpx;
  width: 36rpx; height: 36rpx; border-radius: 50%;
  background: rgba(31,31,31,0.7); color: #fff;
  font-size: 22rpx;
  display: flex; align-items: center; justify-content: center;
}
.photo-add {
  width: 156rpx; height: 156rpx;
  border-radius: var(--radius-md);
  background: var(--surface);
  border: 2rpx dashed var(--ink-4);
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  color: var(--ink-4);
}
.add-plus { font-size: 40rpx; line-height: 1; }
.add-label { font-size: 20rpx; margin-top: 4rpx; }

/* Action bar */
.action-bar {
  position: fixed; left: 0; right: 0; bottom: 0;
  background: var(--surface);
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  display: flex; gap: 20rpx;
  box-shadow: 0 -4rpx 16rpx rgba(31,31,31,0.06);
}
.btn-secondary, .btn-primary {
  height: 92rpx; border-radius: var(--radius-pill);
  font-size: 28rpx; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
}
.btn-secondary {
  flex: 1; background: var(--bg); color: var(--ink-1);
}
.btn-primary {
  flex: 1.6;
  background: linear-gradient(135deg, #F47070 0%, var(--warn) 100%);
  color: #fff;
  box-shadow: 0 12rpx 32rpx rgba(224,78,78,0.3);
}
.btn-primary.disabled { opacity: 0.5; }
