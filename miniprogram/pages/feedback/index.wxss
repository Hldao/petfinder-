.page { min-height: 100vh; background: var(--bg); padding: 28rpx 32rpx; }
.label { font-size: 26rpx; font-weight: 700; color: var(--ink-1); margin: 24rpx 0 16rpx; }
.label:first-child { margin-top: 0; }
.chips { display: flex; gap: 16rpx; }
.chip {
  padding: 14rpx 32rpx; background: var(--surface); border-radius: var(--radius-pill);
  font-size: 26rpx; color: var(--ink-2); font-weight: 600;
}
.chip.active { background: var(--apricot); color: #fff; }
.textarea {
  width: 100%; height: 240rpx; background: var(--surface); border-radius: var(--radius-md);
  padding: 24rpx; font-size: 27rpx; box-sizing: border-box;
}
.submit {
  margin-top: 32rpx; height: 92rpx; border-radius: var(--radius-pill);
  background: var(--apricot); color: #fff; font-size: 30rpx; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
}
.submit.disabled { opacity: 0.5; }
.submit:active { background: var(--apricot-deep); }
