<view class="page">
  <view class="label">反馈类型</view>
  <view class="chips">
    <view wx:for="{{cats}}" wx:key="k" class="chip {{cat===item.k?'active':''}}" data-k="{{item.k}}" bindtap="pickCat">{{item.label}}</view>
  </view>

  <view class="label">具体内容</view>
  <textarea class="textarea" placeholder="说说你遇到的问题或想法，我们会认真看 🙏" value="{{text}}" bindinput="onInput" maxlength="500" />

  <view class="submit {{submitting?'disabled':''}}" bindtap="submit">提交</view>
</view>
