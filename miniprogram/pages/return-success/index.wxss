.page {
  min-height: 100vh; background: var(--bg);
  display: flex; flex-direction: column;
}

.success-scroll {
  flex: 1; overflow-y: auto;
  padding: 60rpx 40rpx 200rpx;
}

/* Hero */
.success-hero {
  text-align: center;
  padding: 40rpx 0 60rpx;
}
.success-circle {
  width: 160rpx; height: 160rpx;
  margin: 0 auto 32rpx;
  background: linear-gradient(135deg, var(--mint) 0%, var(--mint-deep) 100%);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 16rpx 48rpx rgba(91,184,159,0.35), 0 4rpx 12rpx rgba(91,184,159,0.2);
}
.success-check {
  color: #fff; font-size: 80rpx; font-weight: 700;
}
.success-title {
  font-size: 48rpx; font-weight: 800; color: var(--ink-1);
  letter-spacing: -0.01em;
  margin-bottom: 12rpx;
}
.success-sub {
  font-size: 26rpx; color: var(--ink-3);
}

/* 接力人数 */
.reunion-helpers {
  display: flex; align-items: center; justify-content: center; gap: 14rpx;
  background: var(--surface);
  border-radius: var(--radius-md);
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
}
.rh-emoji { font-size: 36rpx; }
.rh-text { font-size: 26rpx; color: var(--ink-2); }
.rh-text .b { font-weight: 800; color: var(--mint-deep); font-size: 32rpx; margin-right: 4rpx; }

/* 致谢卡 */
.reunion-thank-card {
  display: flex; align-items: center; gap: 24rpx;
  background: linear-gradient(135deg, var(--apricot-soft) 0%, #FFF4EB 100%);
  border: 1rpx solid rgba(255,133,82,0.22);
  border-radius: var(--radius-lg);
  padding: 28rpx;
  margin-bottom: 20rpx;
}
.rtc-icon {
  width: 80rpx; height: 80rpx;
  border-radius: 50%; background: #fff;
  display: flex; align-items: center; justify-content: center;
  font-size: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(255,133,82,0.15);
  flex-shrink: 0;
}
.rtc-body { flex: 1; }
.rtc-title { font-size: 28rpx; font-weight: 700; color: var(--apricot-deep); }
.rtc-sub { font-size: 22rpx; color: var(--ink-3); margin-top: 6rpx; }
.rtc-arrow { color: var(--apricot-deep); font-size: 36rpx; font-weight: 300; }

/* 分享卡 */
.reunion-share-card {
  background: var(--surface);
  border-radius: var(--radius-md);
  padding: 22rpx 28rpx;
  margin-bottom: 32rpx;
  box-shadow: var(--shadow-card);
}
.rsc-title {
  font-size: 26rpx; font-weight: 700; color: var(--ink-1);
  margin-bottom: 8rpx;
}
.rsc-sub { font-size: 22rpx; color: var(--ink-3); }

/* 冷却 */
.cooldown-tip {
  text-align: center;
  font-size: 22rpx; color: var(--mint-deep);
  background: var(--mint-soft);
  padding: 14rpx 28rpx;
  border-radius: var(--radius-pill);
  margin: 0 60rpx 24rpx;
}

/* 撤回 */
.undo-link {
  text-align: center;
  font-size: 22rpx; color: var(--ink-4);
  text-decoration: underline;
  text-underline-offset: 4rpx;
}

/* Action bar */
.action-bar {
  position: fixed; left: 0; right: 0; bottom: 0;
  background: var(--surface);
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 16rpx rgba(31,31,31,0.06);
}
.btn-primary {
  height: 92rpx; border-radius: var(--radius-pill);
  background: linear-gradient(135deg, #FFA378 0%, var(--apricot) 100%);
  color: #fff; font-size: 30rpx; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 12rpx 32rpx rgba(255,133,82,0.35);
}
