.page {
  min-height: 100vh; background: var(--bg);
  display: flex; flex-direction: column; align-items: center;
  padding: 160rpx 56rpx 0;
}
.emoji { font-size: 140rpx; }
.title { font-size: 40rpx; font-weight: 800; color: var(--ink-1); margin-top: 24rpx; }
.sub { font-size: 27rpx; color: var(--ink-2); margin-top: 16rpx; }
.cooldown {
  margin-top: 40rpx; font-size: 23rpx; color: var(--mint-deep);
  background: var(--mint-soft); padding: 14rpx 28rpx; border-radius: var(--radius-pill);
}
.cta {
  margin-top: 80rpx; width: 100%; height: 92rpx; border-radius: var(--radius-pill);
  background: var(--apricot); color: #fff; font-size: 30rpx; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
}
.cta:active { background: var(--apricot-deep); }
.undo { margin-top: 28rpx; font-size: 23rpx; color: var(--ink-4); }
