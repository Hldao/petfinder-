.page {
  min-height: 100vh; background: var(--bg);
  display: flex; flex-direction: column;
}
.empty { text-align: center; color: var(--ink-3); padding: 120rpx 0; font-size: 28rpx; }

.scroll-area { flex: 1; overflow-y: auto; padding-bottom: 200rpx; }

/* Hero · 220px 高 = 440rpx */
.hero {
  margin: 28rpx 32rpx 0;
  height: 440rpx;
  border-radius: 44rpx;
  position: relative;
  display: flex; align-items: center; justify-content: center;
  overflow: hidden;
}
.hero.lost  { background: linear-gradient(135deg, var(--apricot-soft) 0%, #FFCDA8 100%); }
.hero.found { background: linear-gradient(135deg, var(--mint-soft) 0%, #ABDDCB 100%); }
.hero-emoji { font-size: 200rpx; }

/* hero badge · 与 status-bubble 同源 */
.hero-status {
  position: absolute; top: 28rpx; left: 28rpx;
  padding: 10rpx 28rpx;
  border-radius: var(--radius-pill);
  font-size: 23rpx; font-weight: 700; color: #fff;
  letter-spacing: 0.02em;
  box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.12), 0 0 0 4rpx rgba(255,255,255,0.95);
}
.hero-status.lost  { background: var(--apricot); }
.hero-status.found { background: var(--mint); }

.hero-time {
  position: absolute; top: 28rpx; right: 28rpx;
  padding: 8rpx 24rpx;
  background: rgba(255,255,255,0.95);
  border-radius: var(--radius-pill);
  font-size: 22rpx; font-weight: 700; color: var(--ink-2);
  letter-spacing: 0.04em;
}

/* Detail body */
.detail-body { padding: 40rpx 36rpx; }
.detail-name {
  font-size: 52rpx; font-weight: 700; letter-spacing: -0.01em;
  line-height: 1.3; margin-bottom: 8rpx; color: var(--ink-1);
}
.detail-subtitle {
  font-size: 26rpx; color: var(--ink-3);
  margin-bottom: 28rpx;
}

/* 距离条 */
.detail-dist-bar {
  background: linear-gradient(135deg, var(--apricot-soft), #FFD8C0);
  border: 1rpx solid rgba(255,133,82,0.25);
  border-radius: var(--radius-md);
  padding: 22rpx 28rpx;
  margin-bottom: 28rpx;
  display: flex; align-items: center; gap: 20rpx;
}
.dist-bar-icon { font-size: 40rpx; }
.dist-bar-text { flex: 1; }
.dist-bar-main {
  font-size: 28rpx; font-weight: 700; color: var(--apricot-deep);
}
.dist-bar-sub {
  font-size: 22rpx; color: var(--ink-3); margin-top: 4rpx;
}

/* Info Grid 2x2 */
.info-grid {
  background: var(--surface);
  border-radius: var(--radius-md);
  padding: 8rpx 0;
  margin-bottom: 28rpx;
  box-shadow: var(--shadow-card);
  display: grid;
  grid-template-columns: 1fr 1fr;
}
.info-cell {
  padding: 24rpx 28rpx;
  position: relative;
}
.info-cell:nth-child(even)::before {
  content: '';
  position: absolute; left: 0; top: 16rpx; bottom: 16rpx;
  width: 1rpx; background: var(--divider-soft);
}
.info-cell .label {
  font-size: 20rpx; color: var(--ink-3);
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  margin-bottom: 8rpx;
}
.info-cell .value {
  font-size: 28rpx; font-weight: 700; color: var(--ink-1);
}

/* 招领额外信息 */
.info-extra {
  background: var(--surface);
  border-radius: var(--radius-md);
  margin-bottom: 28rpx;
  box-shadow: var(--shadow-card);
  overflow: hidden;
}
.info-extra-row {
  padding: 24rpx 28rpx;
  display: flex; align-items: center; gap: 20rpx;
  border-bottom: 1rpx solid var(--divider-soft);
}
.info-extra-row:last-child { border-bottom: none; }
.ie-icon {
  width: 60rpx; height: 60rpx;
  border-radius: 20rpx;
  background: var(--mint-soft);
  color: var(--mint-deep);
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; flex-shrink: 0;
}
.ie-icon.honey { background: var(--honey-soft); color: var(--honey-deep); }
.ie-label {
  font-size: 22rpx; color: var(--ink-3); font-weight: 600;
  width: 120rpx; flex-shrink: 0;
}
.ie-value {
  font-size: 26rpx; font-weight: 600; color: var(--ink-1);
  flex: 1;
}

/* Section label */
.section-label {
  font-size: 22rpx; font-weight: 700; color: var(--ink-3);
  letter-spacing: 0.04em; margin: 12rpx 0 16rpx;
  display: flex; align-items: center; gap: 12rpx;
}
.section-label .count { color: var(--apricot-deep); }

/* Desc card */
.desc-card {
  background: var(--surface);
  border-radius: var(--radius-md);
  padding: 28rpx 32rpx;
  font-size: 27rpx; color: var(--ink-2);
  line-height: 1.7;
  margin-bottom: 28rpx;
  box-shadow: var(--shadow-card);
}

/* Feature card · 兜底空状态 */
.feature-card {
  background: var(--honey-soft);
  border-radius: var(--radius-md);
  padding: 22rpx 28rpx;
  margin-bottom: 20rpx;
  display: flex; gap: 16rpx;
  font-size: 26rpx; color: var(--honey-deep);
  line-height: 1.6;
}
.feature-card.green { background: var(--mint-soft); color: var(--mint-deep); }
.feature-card .ic { font-size: 30rpx; flex-shrink: 0; }

/* Clue card */
.clue-card {
  background: var(--surface);
  border-radius: var(--radius-md);
  padding: 24rpx 28rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-card);
}
.clue-body { display: flex; gap: 22rpx; }
.clue-avatar {
  width: 64rpx; height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #B0B7BF, #7A828B);
  color: #fff; font-weight: 700; font-size: 26rpx;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.clue-info { flex: 1; min-width: 0; }
.clue-top {
  display: flex; align-items: center; gap: 16rpx;
  margin-bottom: 10rpx; flex-wrap: wrap;
}
.clue-loc-time {
  font-size: 25rpx; font-weight: 700; color: var(--ink-1);
}
.clue-badge {
  font-size: 20rpx;
  padding: 2rpx 14rpx;
  background: var(--mint-soft); color: var(--mint-deep);
  border-radius: var(--radius-pill); font-weight: 700;
}
.clue-text {
  font-size: 25rpx; color: var(--ink-2); line-height: 1.6;
}

/* Action bar · 双 CTA */
.action-bar {
  position: fixed; left: 0; right: 0; bottom: 0;
  background: var(--surface);
  border-top: 1rpx solid var(--divider);
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  display: flex; gap: 20rpx;
  z-index: 15;
}
.btn-secondary, .btn-primary {
  height: 92rpx; border-radius: 28rpx;
  font-size: 28rpx; font-weight: 700;
  display: flex; align-items: center; justify-content: center; gap: 12rpx;
}
.btn-secondary {
  flex: 1; background: var(--bg); color: var(--ink-1);
}
.btn-primary {
  flex: 1.4;
  background: linear-gradient(135deg, #FFA378 0%, var(--apricot) 100%);
  color: #fff;
  box-shadow: 0 12rpx 32rpx rgba(255,133,82,0.35), 0 4rpx 12rpx rgba(255,133,82,0.2);
}
.btn-secondary:active, .btn-primary:active { transform: scale(0.98); }
