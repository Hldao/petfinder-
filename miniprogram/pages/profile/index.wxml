<view class="page">
  <view class="profile-titlebar">我的</view>

  <!-- Hero · r44 工具入口列表风格 -->
  <view class="profile-hero">
    <view class="profile-user">
      <view class="profile-avatar">😊</view>
      <view class="profile-info">
        <view class="profile-name">客栈老板娘</view>
        <view class="profile-handle">📍 大理古城</view>
      </view>
    </view>
  </view>

  <view class="profile-content">
    <!-- 高频入口大号 banner · r46 -->
    <view class="profile-feature-card" bindtap="onMyPosts">
      <view class="pfc-icon">✏</view>
      <view class="pfc-body">
        <view class="pfc-title">我的发布</view>
        <view class="pfc-sub">查看进行中 / 已完成的帖子</view>
      </view>
      <view class="pfc-arrow">›</view>
    </view>

    <view class="menu-section-label">通知</view>
    <view class="menu-section">
      <view class="menu-row" data-label="关注公众号" bindtap="onMenu">
        <view class="menu-icon mi-mint">📣</view>
        <view class="menu-label">关注公众号</view>
        <view class="menu-meta">推送更及时</view>
        <view class="menu-arrow">›</view>
      </view>
    </view>

    <view class="menu-section-label">反馈与申诉</view>
    <view class="menu-section">
      <view class="menu-row" data-label="意见反馈" bindtap="onMenu">
        <view class="menu-icon mi-apricot">💬</view>
        <view class="menu-label">意见反馈</view>
        <view class="menu-arrow">›</view>
      </view>
      <view class="menu-row" data-label="争议申诉" bindtap="onMenu">
        <view class="menu-icon mi-warn">⚠</view>
        <view class="menu-label">争议申诉</view>
        <view class="menu-arrow">›</view>
      </view>
      <view class="menu-row" data-label="黑名单" bindtap="onMenu">
        <view class="menu-icon mi-ink">🚫</view>
        <view class="menu-label">黑名单</view>
        <view class="menu-arrow">›</view>
      </view>
    </view>

    <view class="menu-section-label">合规与设置</view>
    <view class="menu-section">
      <view class="menu-row" data-label="用户协议" bindtap="onMenu">
        <view class="menu-icon mi-ink">📄</view>
        <view class="menu-label">用户协议</view>
        <view class="menu-arrow">›</view>
      </view>
      <view class="menu-row" data-label="隐私政策" bindtap="onMenu">
        <view class="menu-icon mi-ink">🔒</view>
        <view class="menu-label">隐私政策</view>
        <view class="menu-arrow">›</view>
      </view>
      <view class="menu-row" data-label="清除我的数据" bindtap="onMenu">
        <view class="menu-icon mi-warn">🗑</view>
        <view class="menu-label">清除我的数据</view>
        <view class="menu-arrow">›</view>
      </view>
    </view>

    <view class="footer-info">
      <view class="footer-about">ⓘ 关于寻宠 · 大理 <text class="version">v1.0.0</text></view>
      ICP 备案号 XXXXX · 公安备案 XXXXX
      <view>主体 · XX 个体工商户</view>
    </view>
  </view>
</view>
