<view class="page">
  <view class="scroll-area">
    <!-- Hero · 温暖头 -->
    <view class="thanks-hero">
      <view class="th-icon">🙏</view>
      <view class="th-title">{{pet ? pet + ' 回家了' : 'ta 回家了'}}</view>
      <view class="th-sub">写一句话谢谢一路接力的人 · 站内信送达</view>
    </view>

    <!-- 文字 -->
    <view class="section-label">想说的话</view>
    <view class="block">
      <textarea class="textarea" placeholder="谢谢你们的每一次转发、每一条线索…" value="{{text}}" bindinput="onInput" maxlength="300" />
      <view class="count">{{text.length}} / 300</view>
    </view>

    <!-- 合影 -->
    <view class="section-label">附张合影（选填）</view>
    <view class="photo-row">
      <view wx:if="{{photo}}" class="photo-slot">
        <image src="{{photo}}" mode="aspectFill" class="photo-img" />
        <view class="photo-del" catchtap="removePhoto">✕</view>
      </view>
      <view wx:else class="photo-add" bindtap="choosePhoto">
        <view class="add-plus">+</view>
        <view class="add-label">合影</view>
      </view>
    </view>
  </view>

  <view class="action-bar">
    <view class="btn-secondary" bindtap="skip">先不写</view>
    <view class="btn-primary {{submitting?'disabled':''}}" bindtap="submit">送出感谢</view>
  </view>
</view>
