.page {
  min-height: 100vh; background: var(--bg);
  display: flex; flex-direction: column;
}
.scroll-area {
  flex: 1; overflow-y: auto;
  padding: 40rpx 32rpx 200rpx;
}

/* Hero · 温暖 */
.thanks-hero {
  background: linear-gradient(135deg, var(--mint-soft) 0%, #ABDDCB 100%);
  border-radius: var(--radius-lg);
  padding: 40rpx 32rpx;
  text-align: center;
  margin-bottom: 32rpx;
  box-shadow: 0 12rpx 32rpx rgba(91,184,159,0.15);
}
.th-icon {
  width: 96rpx; height: 96rpx;
  margin: 0 auto 20rpx;
  background: #fff;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(91,184,159,0.2);
}
.th-title { font-size: 36rpx; font-weight: 800; color: var(--mint-deep); margin-bottom: 8rpx; }
.th-sub { font-size: 24rpx; color: var(--mint-deep); opacity: 0.85; }

/* Section label */
.section-label {
  font-size: 22rpx; color: var(--ink-3); font-weight: 700;
  letter-spacing: 0.08em; text-transform: uppercase;
  padding: 8rpx 8rpx 14rpx;
}

/* 文本 block */
.block {
  background: var(--surface);
  border-radius: var(--radius-md);
  padding: 20rpx 28rpx;
  box-shadow: var(--shadow-card);
  position: relative;
}
.textarea {
  width: 100%; box-sizing: border-box;
  font-size: 27rpx; color: var(--ink-1);
  min-height: 240rpx;
  line-height: 1.7;
}
.count {
  text-align: right;
  font-size: 21rpx; color: var(--ink-4);
  padding-top: 8rpx;
}

/* 照片 */
.photo-row { display: flex; padding: 8rpx 0; }
.photo-slot {
  width: 200rpx; height: 200rpx;
  border-radius: var(--radius-md);
  position: relative;
}
.photo-img { width: 100%; height: 100%; border-radius: var(--radius-md); }
.photo-del {
  position: absolute; top: -10rpx; right: -10rpx;
  width: 36rpx; height: 36rpx; border-radius: 50%;
  background: rgba(31,31,31,0.7); color: #fff;
  font-size: 22rpx;
  display: flex; align-items: center; justify-content: center;
}
.photo-add {
  width: 200rpx; height: 200rpx;
  border-radius: var(--radius-md);
  background: var(--surface);
  border: 2rpx dashed var(--ink-4);
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  color: var(--ink-4);
}
.add-plus { font-size: 40rpx; line-height: 1; }
.add-label { font-size: 20rpx; margin-top: 4rpx; }

/* Action bar */
.action-bar {
  position: fixed; left: 0; right: 0; bottom: 0;
  background: var(--surface);
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  display: flex; gap: 20rpx;
  box-shadow: 0 -4rpx 16rpx rgba(31,31,31,0.06);
}
.btn-secondary, .btn-primary {
  height: 92rpx; border-radius: var(--radius-pill);
  font-size: 28rpx; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
}
.btn-secondary {
  flex: 1; background: var(--bg); color: var(--ink-1);
}
.btn-primary {
  flex: 1.6;
  background: linear-gradient(135deg, #6CC9AC 0%, var(--mint-deep) 100%);
  color: #fff;
  box-shadow: 0 12rpx 32rpx rgba(91,184,159,0.35);
}
.btn-primary.disabled { opacity: 0.5; }
