.page { min-height: 100vh; background: var(--bg); padding: 28rpx 32rpx; }
.head {
  background: var(--mint-soft); color: var(--mint-deep);
  border-radius: var(--radius-md); padding: 22rpx 24rpx; font-size: 26rpx; font-weight: 700; line-height: 1.5;
}
.label { font-size: 26rpx; font-weight: 700; color: var(--ink-1); margin: 28rpx 0 16rpx; }
.label .req { color: var(--warn); }
.textarea {
  width: 100%; height: 220rpx; background: var(--surface); border-radius: var(--radius-md);
  padding: 24rpx; font-size: 27rpx; box-sizing: border-box;
}
.photo-row { display: flex; }
.photo-slot, .photo-add { width: 168rpx; height: 168rpx; border-radius: var(--radius-md); position: relative; }
.photo-img { width: 100%; height: 100%; border-radius: var(--radius-md); }
.photo-del {
  position: absolute; top: -10rpx; right: -10rpx; width: 36rpx; height: 36rpx; border-radius: 50%;
  background: rgba(31,31,31,0.7); color: #fff; font-size: 22rpx;
  display: flex; align-items: center; justify-content: center;
}
.photo-add {
  background: var(--surface); border: 2rpx dashed var(--ink-4);
  display: flex; align-items: center; justify-content: center; font-size: 56rpx; color: var(--ink-4); font-weight: 300;
}
.submit {
  margin-top: 36rpx; height: 92rpx; border-radius: var(--radius-pill);
  background: var(--mint); color: #fff; font-size: 30rpx; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
}
.submit.disabled { opacity: 0.5; }
.submit:active { background: var(--mint-deep); }
