<view class="page">
  <!-- 顶部宠物卡 + ⋯ 菜单 -->
  <view class="pet-bar">
    <text class="pet-emoji">{{emoji}}</text>
    <text class="pet-name">{{petName ? '关于 ' + petName : '会话'}}</text>
    <view class="more-btn" bindtap="onMore">⋯</view>
  </view>

  <!-- 审核提示条（03 §4.2）-->
  <view class="audit-bar">🛡 消息经审核后送达 · 含微信号 / 电话 / 二维码将被过滤</view>

  <!-- 消息流 -->
  <scroll-view scroll-y class="stream" scroll-into-view="{{scrollId}}" scroll-with-animation>
    <view wx:for="{{messages}}" wx:key="index" id="msg-{{index}}" class="msg {{item.mine ? 'mine' : 'peer'}}">
      <view class="bubble">{{item.content}}</view>
      <view class="time">{{item.time}}</view>
    </view>
    <view wx:if="{{messages.length === 0}}" class="empty-hint">开始和 {{peerName}} 聊聊吧</view>
    <view class="stream-pad"></view>
  </scroll-view>

  <!-- Quick Reply -->
  <scroll-view scroll-x class="quick-row">
    <view wx:for="{{quick}}" wx:key="label" class="quick-chip" data-text="{{item.text}}" bindtap="pickQuick">{{item.label}}</view>
  </scroll-view>

  <!-- 输入栏 -->
  <view class="input-bar">
    <input class="chat-input" placeholder="输入消息…" value="{{input}}" bindinput="onInput" confirm-type="send" bindconfirm="send" />
    <view class="send-btn" bindtap="send">↑</view>
  </view>
</view>
