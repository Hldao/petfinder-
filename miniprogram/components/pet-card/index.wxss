.pet-card {
  background: var(--surface);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-card);
}
.pet-card { transition: transform 0.1s; }
.pet-card:active { transform: scale(0.99); }

.pc-body { display: flex; padding: 24rpx; gap: 24rpx; }
.pc-photo {
  width: 168rpx; height: 168rpx; border-radius: var(--radius-md);
  display: flex; align-items: center; justify-content: center;
  position: relative; flex-shrink: 0;
}
.pc-photo.lost  { background: linear-gradient(135deg, var(--apricot-soft) 0%, #FFCDA8 100%); }
.pc-photo.found { background: linear-gradient(135deg, var(--mint-soft) 0%, #ABDDCB 100%); }
.pc-photo .emoji { font-size: 76rpx; }

.status-bubble {
  position: absolute; top: -10rpx; left: -10rpx;
  padding: 6rpx 18rpx; border-radius: var(--radius-pill);
  font-size: 21rpx; font-weight: 700; color: #fff;
}
.status-bubble.lost  { background: var(--apricot); }
.status-bubble.found { background: var(--mint); }

.pc-info { flex: 1; min-width: 0; padding-top: 4rpx; }
.pc-name-row { display: flex; align-items: baseline; gap: 12rpx; margin-bottom: 8rpx; }
.pc-name { font-size: 32rpx; font-weight: 700; }
.breed { font-size: 23rpx; color: var(--ink-3); font-weight: 500; }
.pc-meta { font-size: 24rpx; color: var(--ink-3); margin-bottom: 8rpx; }
.pc-meta .time { color: var(--ink-3); }
.emo-time { font-size: 22rpx; color: var(--apricot-deep); font-weight: 600; margin-bottom: 8rpx; }
.emo-time.longterm { color: var(--warn-deep); }
.pc-desc {
  font-size: 25rpx; color: var(--ink-2); line-height: 1.55;
  overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
}

.pc-footer {
  display: flex; align-items: center; gap: 16rpx;
  padding: 20rpx 24rpx; border-top: 2rpx solid var(--divider-soft);
}
.pc-action { font-size: 23rpx; color: var(--ink-3); font-weight: 600; }
.pc-action.share {
  margin-left: auto; color: var(--apricot-deep);
  background: var(--apricot-soft); padding: 8rpx 20rpx; border-radius: var(--radius-pill); font-weight: 700;
}
/* 我发布的小标识 · r125 footer 左侧 */
.pc-mine {
  display: inline-flex; align-items: center; gap: 6rpx;
  padding: 6rpx 18rpx;
  background: var(--apricot-soft);
  color: var(--apricot-deep);
  border-radius: 999rpx;
  font-size: 21rpx; font-weight: 700;
  letter-spacing: 0.02em;
  flex-shrink: 0;
}
