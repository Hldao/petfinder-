.tab-bar {
  position: fixed; left: 0; right: 0; bottom: 0; z-index: 100;
  height: 100rpx; display: flex;
  padding-bottom: env(safe-area-inset-bottom);
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(31,31,31,0.06);
}
.tab-item {
  flex: 1; display: flex; flex-direction: column;
  align-items: center; justify-content: center; gap: 4rpx;
  color: #7A7A7A;
}
.tab-item.active { color: #E66A38; }
.ti-icon { font-size: 40rpx; line-height: 1; }
.ti-text { font-size: 20rpx; font-weight: 600; }

/* 中央凸起 FAB */
.fab {
  position: absolute; left: 50%; top: -24rpx;
  transform: translateX(-50%);
  width: 108rpx; height: 108rpx; border-radius: 50%;
  background: linear-gradient(135deg, #FF8552, #E66A38);
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 6rpx 16rpx rgba(255,133,82,0.4);
  border: 6rpx solid #fff;
}
.fab-plus { color: #fff; font-size: 56rpx; line-height: 1; font-weight: 300; }
.fab:active { transform: translateX(-50%) scale(0.95); }
